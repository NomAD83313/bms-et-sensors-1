{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ESP-IDF: Set Target ESP32-C6",
      "type": "shell",
      "command": "source /home/ets/.espressif/tools/activate_idf_v5.4.1.sh >/dev/null && python \"$IDF_PATH/tools/idf.py\" set-target esp32c6",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "ESP-IDF: Build",
      "type": "shell",
      "command": "source /home/ets/.espressif/tools/activate_idf_v5.4.1.sh >/dev/null && python \"$IDF_PATH/tools/idf.py\" build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "ESP-IDF: Flash and Monitor",
      "type": "shell",
      "command": "source /home/ets/.espressif/tools/activate_idf_v5.4.1.sh >/dev/null && python \"$IDF_PATH/tools/idf.py\" -p \"${input:serialPort}\" flash monitor",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "ESP-IDF: Monitor",
      "type": "shell",
      "command": "source /home/ets/.espressif/tools/activate_idf_v5.4.1.sh >/dev/null && python \"$IDF_PATH/tools/idf.py\" -p \"${input:serialPort}\" monitor",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "serialPort",
      "type": "promptString",
      "description": "Remote Linux serial port for ESP32-C6-Zero",
      "default": "/dev/ttyACM0"
    }
  ]
}

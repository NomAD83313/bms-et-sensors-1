INFLUX_ORG=my-org
INFLUX_BUCKET=daq_data
INFLUX_TOKEN=change-me
INFLUX_ADMIN_PASSWORD=change-me
GRAFANA_ADMIN_PASSWORD=change-me

MSCL_NODE_IDS=16904,16900
# Optional fixed MSCL base station path. Prefer autodetect unless a host has
# multiple matching USB serial devices.
# MSCL_PORT=/dev/serial/by-id/...

# Optional device selection for hosts with multiple matching devices.
# ALMEMO_PORT=/dev/serial/by-id/...
# REDLAB_ACTIVE_UNIQUE_ID=

# Host-specific RCP settings. Use /dev/ttyOTBR with OTBR_RCP_TCP_ENDPOINT for
# network RCP bridges, or a stable /dev/serial/by-id/... path for USB RCP dongles.
OTBR_RCP_DEVICE=/dev/ttyOTBR
OTBR_RCP_TCP_ENDPOINT=10.42.0.2:6638
OTBR_RCP_BAUD=460800
# OTBR_INFRA_IF=wlan1

MATTER_POLL_INTERVAL_SEC=60
MATTER_POLL_NODE_ID=1
MATTER_POLL_BATTERY_ENDPOINT_ID=5
# MATTER_PRIMARY_IF=wlan1
# MATTER_BLE_MODE=internal
# MATTER_BLE_MODE=disabled

# Pyrometer serials are host-specific. Edit runtime/pyrometers-devices.json with
# scripts/pyrometers-setup.sh; config/pyrometers-devices.example.json is only a template.

# Host-specific AP settings. Change AP_INTERFACE if the AP Wi-Fi device is not wlan1.
AP_INTERFACE=wlan1
AP_SSID=BMSensors
AP_PASSWORD=ChangeMe12345
AP_CHANNEL=4
AP_LOCAL_DNS_NAME=rpi5.internal
# AP_UI_INTERFACE=wlan1
# AP_UI_PROFILE=rpi-ap

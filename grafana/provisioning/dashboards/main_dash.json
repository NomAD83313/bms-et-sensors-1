            "uid": "InfluxDB_Flux"
          },
          "query": "import \"math\"\nfrom(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"redlab\")\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> aggregateWindow(every: duration(v: int(v: math.mMax(x: float(v: int(v: v.windowPeriod)), y: 5000000000.0))), fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with series: if exists r.device and r.device != \"\" then r.device + \" \" + r.channel else r.channel }))\n  |> keep(columns: [\"_time\", \"_value\", \"series\"])\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"series\"], valueColumn: \"_value\")",
          "refId": "A"
        }
      ],
      "title": "RedLab-TC Historical Data",
      "type": "timeseries"
    },
